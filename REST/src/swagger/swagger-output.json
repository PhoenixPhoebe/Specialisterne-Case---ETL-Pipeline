{
  "swagger": "2.0",
  "info": {
    "version": "v1.0.0",
    "title": "Specialisterne ETL process API",
    "description": "This is the API dokumentation for an assigment creating REST APIs showing data collected from weather stations"
  },
  "host": "localhost:3000/VejrData",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "paths": {
    "/stations": {
      "get": {
        "tags": [
          "DMI"
        ],
        "description": "This enpoint returns a list of weather \r  stations that has been collected data from.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Somthing went wrong with the request"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/dmi/{id}": {
      "get": {
        "tags": [
          "DMI"
        ],
        "description": "This enpoint returns a list of DMI data for a specific station.\r  The station is identified by its id, which is passed as a path parameter.\r  It",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer"
          },
          {
            "name": "pagesize",
            "in": "query",
            "required": false,
            "type": "integer"
          },
          {
            "name": "parameter",
            "in": "query",
            "description": "Weather parameter to filter by",
            "type": "string",
            "enum": [
              "temperature",
              "humidity",
              "pressure"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Somthing went wrong with the request"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/spe/{sensor}": {
      "get": {
        "tags": [
          "Specialisterne data"
        ],
        "description": "This enpoint returns a list of data from Specialisterne for a specific Sensor.\r  The sensor is identified by its type, which is passed as a path parameter.\r  It",
        "parameters": [
          {
            "name": "sensor",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer"
          },
          {
            "name": "pagesize",
            "in": "query",
            "required": false,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Somthing went wrong with the request"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/temperature": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of temperature readings from all stations.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/temperature/latest": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of the latest readings for temperature from all stations.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/temperature/outside": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of combined temperature readings from the outside location for all stations.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/data/humidity": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of humidity readings from all stations.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/humidity/latest": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of the latest readings for humidity from all stations.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/pressure": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of pressure readings from all stations.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/data/pressure/latest": {
      "get": {
        "tags": [
          "Readings"
        ],
        "description": "This enpoint returns a list of the latest readings for pressure from all stations.",
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Request is valid but no data was found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}